// Helper library with math functions
package helper:lib;

/// Math operations interface
interface math {
    /// Add two numbers
    add: func(a: s32, b: s32) -> s32 {
        a + b;
    }
    
    /// Multiply two numbers
    multiply: func(a: s32, b: s32) -> s32 {
        a * b;
    }
}

world math-world {
    export math;
}
