// Resource Types Example with Implementations
package example:resources;

interface counter-api {
    resource counter {
        constructor(initial: s32) {
            initial;
        }
        
        get: func() -> s32 {
            self;
        }
        
        increment: func() {
            let x = 1;
        }
        
        add: func(n: s32) {
            let sum = n + 1;
        }
        
        zero: static func() -> s32 {
            0;
        }
    }
}

world resources-world {
    export counter-api;
}
