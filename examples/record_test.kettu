// Record Tests
package example:record-tests;

interface record-tests {
    @test
    test-record-literal-field: func() -> bool {
        return { x: 10, y: 20 }.x == 10;
    }

    @test
    test-record-var-first-field: func() -> bool {
        let rec = { x: 10, y: 20 };
        return rec.x == 10;
    }

    @test
    test-record-var-second-field: func() -> bool {
        let rec = { x: 10, y: 20 };
        return rec.y == 20;
    }

    @test
    test-record-var-multiple-fields: func() -> bool {
        let r = { a: 1, b: 2, c: 3 };
        return r.b == 2;
    }
}

world tests {
    export record-tests;
}
