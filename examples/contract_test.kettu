package local:contract-tests;

interface contract-tests {

    /// A type alias with a constraint: values must be positive.
    type positive = s32 where it > 0;

    /// A function with an explicit where clause on its parameters.
    in-range: func(lo: s32, hi: s32 where hi > lo) -> result<bool, string> {
        result#ok(true)
    }

    /// A function using a constrained type alias on its parameter.
    count-items: func(n: positive) -> result<bool, string> {
        result#ok(true)
    }

    /// Test: calling a constrained function with satisfying arguments.
    @test
    test-in-range-satisfied: func() -> bool {
        guard let result = in-range(1, 10) else {
            return false;
        };
        result
    }

    /// Test: calling a type-aliased constrained function.
    @test
    test-positive-satisfied: func() -> bool {
        guard let result = count-items(5) else {
            return false;
        };
        result
    }

    /// Test helper: wraps count-items so the checker cannot prove
    /// the constraint at compile time. Guard let catches runtime
    /// violations and returns false.
    @test-helper
    try-count-items: func(n: s32) -> bool {
        guard let result = count-items(n) else {
            return false;
        };
        result
    }

    /// Test: a negative number is rejected at runtime by the constraint.
    /// The checker allows this because it cannot see through the helper.
    @test
    test-negative-rejected: func() -> bool {
        try-count-items(-1) == false
    }

    /// Test helper: unconstrained params require guard let when
    /// forwarding to a constrained function.
    @test-helper
    check-range: func(lo: s32, hi: s32) -> bool {
        guard let result = in-range(lo, hi) else {
            return false;
        };
        result
    }

    /// Test: transitive constraint via test helper.
    @test
    test-via-helper: func() -> bool {
        check-range(0, 100)
    }
}

world tests {
    export contract-tests;
}
