{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Install Extension Dependencies",
            "type": "shell",
            "command": "npm",
            "args": ["install"],
            "options": {
                "cwd": "${workspaceFolder}/crates/kettu-cli/editors/vscode"
            },
            "problemMatcher": []
        },
        {
            "label": "Build Kettu",
            "type": "shell",
            "command": "cargo",
            "args": ["build", "--bin", "kettu"],
            "options": {
                "cwd": "${workspaceFolder}/crates/kettu-cli"
            },
            "dependsOn": "Install Extension Dependencies",
            "problemMatcher": ["$rustc"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
