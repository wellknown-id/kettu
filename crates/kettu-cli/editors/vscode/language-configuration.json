{
    "comments": {
        "lineComment": "//",
        "blockComment": ["/*", "*/"]
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        { "open": "{", "close": "}" },
        { "open": "[", "close": "]" },
        { "open": "(", "close": ")" },
        { "open": "<", "close": ">" },
        { "open": "\"", "close": "\"", "notIn": ["string"] }
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["<", ">"],
        ["\"", "\""]
    ],
    "folding": {
        "markers": {
            "start": "^\\s*(package|interface|world|record|variant|enum|flags|resource|func.*\\{)",
            "end": "^\\s*\\}"
        }
    },
    "wordPattern": "[a-zA-Z_][a-zA-Z0-9_-]*"
}
