{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "WitFile",
  "scopeName": "source.wit",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#identifiers"
    },
    {
      "begin": "<",
      "end": ">",
      "name": "meta.block.angle.wit",
      "patterns": [
        {
          "include": "$self"
        }
      ]
    },
    {
      "begin": "\\(",
      "end": "\\)",
      "name": "meta.block.paren.wit",
      "patterns": [
        {
          "include": "$self"
        }
      ]
    },
    {
      "begin": "\\{",
      "end": "\\}",
      "name": "meta.block.brace.wit",
      "patterns": [
        {
          "include": "$self"
        }
      ]
    },
    {
      "begin": "\\[",
      "end": "\\]",
      "name": "meta.block.bracket.wit",
      "patterns": [
        {
          "include": "$self"
        }
      ]
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "match": "//.*$",
          "name": "comment.line.double-slash.wit"
        },
        {
          "begin": "/\\*",
          "end": "\\*/",
          "name": "comment.block.wit"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(?:package|use|as|version|feature|interface|record|variant|enum|flags|type|resource|constructor|static|func|bool|char|string|list|option|result|tuple|future|stream|async|let|return|break|continue|true|false|assert|await|if|else|while|for|in|to|downto|step|match|_|map|filter|reduce|some|none|ok|err|world|import|export|include)\\b",
          "name": "keyword.control.wit"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "match": ";|:|@|/|@since|\\(|=|\\)|@unstable|@deprecated|@test|\\{|\\}|\\.|,|<|>|u8|u16|u32|u64|s8|s16|s32|s64|f32|f64|->|!|\\|\\||&&|==|!=|<=|>=|\\+|-|\\*|\\?|\\?\\.|\\[|\\]|\\.\\.|#|=>|str-len|str-eq|list-len|list-set|list-push|\\|",
          "name": "keyword.operator.wit"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "match": "[0-9]+",
          "name": "constant.numeric.wit"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "match": "\"[^\"]*\"",
          "name": "string.quoted.wit"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "match": "[%]?[a-zA-Z_][a-zA-Z0-9_-]*",
          "name": "variable.other.wit"
        },
        {
          "match": "[0-9]+\\.[0-9]+\\.[0-9]+(?:-[A-Za-z0-9-]+(?:\\.[A-Za-z0-9-]+)*)?",
          "name": "variable.other.wit"
        }
      ]
    }
  }
}