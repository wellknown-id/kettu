{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "WitFile",
  "scopeName": "source.kettu",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#identifiers"
    },
    {
      "begin": "<",
      "end": ">",
      "name": "meta.block.angle.kettu",
      "patterns": [
        {
          "include": "$self"
        }
      ]
    },
    {
      "begin": "\\(",
      "end": "\\)",
      "name": "meta.block.paren.kettu",
      "patterns": [
        {
          "include": "$self"
        }
      ]
    },
    {
      "begin": "\\{",
      "end": "\\}",
      "name": "meta.block.brace.kettu",
      "patterns": [
        {
          "include": "$self"
        }
      ]
    },
    {
      "begin": "\\[",
      "end": "\\]",
      "name": "meta.block.bracket.kettu",
      "patterns": [
        {
          "include": "$self"
        }
      ]
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "match": "//.*$",
          "name": "comment.line.double-slash.kettu"
        },
        {
          "begin": "/\\*",
          "end": "\\*/",
          "name": "comment.block.kettu"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(?:package|use|as|version|feature|interface|record|variant|enum|flags|type|resource|constructor|static|func|bool|char|string|list|option|result|tuple|future|stream|async|where|let|shared|return|break|continue|guard|else|true|false|assert|await|if|while|for|in|to|downto|step|simd|match|_|map|filter|reduce|some|none|ok|err|atomic|load|store|add|sub|cmpxchg|wait|notify|spawn|thread|join|world|import|export|include)\\b",
          "name": "keyword.control.kettu"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "match": ";|:|@|/|@since|\\(|=|\\)|@unstable|@deprecated|@test|@test-helper|\\{|\\}|\\.|,|<|>|u8|u16|u32|u64|s8|s16|s32|s64|f32|f64|->|\\+=|-=|!|-|\\|\\||&&|==|!=|<=|>=|\\+|\\*|\\?|\\?\\.|\\[|\\]|\\.\\.|#|=>|str-len|str-eq|list-len|list-set|list-push|\\||v128|i8x16|i16x8|i32x4|i64x2|f32x4|f64x2",
          "name": "keyword.operator.kettu"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "match": "[0-9]+",
          "name": "constant.numeric.kettu"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "match": "\"[^\"]*\"",
          "name": "string.quoted.kettu"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "match": "[%]?[a-zA-Z_][a-zA-Z0-9_-]*",
          "name": "variable.other.kettu"
        },
        {
          "match": "[0-9]+\\.[0-9]+\\.[0-9]+(?:-[A-Za-z0-9-]+(?:\\.[A-Za-z0-9-]+)*)?",
          "name": "variable.other.kettu"
        }
      ]
    }
  }
}