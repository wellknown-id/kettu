{
    "name": "kettu",
    "displayName": "Kettu",
    "description": "Kettu language support — LSP diagnostics, syntax highlighting, and MCP tools for AI chat",
    "version": "0.1.0",
    "publisher": "kettu",
    "engines": {
        "vscode": "^1.99.0"
    },
    "categories": [
        "Programming Languages",
        "AI",
        "Chat"
    ],
    "activationEvents": [
        "onStartupFinished",
        "onDebugResolve:kettu",
        "onDebugInitialConfigurations",
        "onCommand:kettu.debugCurrentFileTests"
    ],
    "main": "./extension.js",
    "contributes": {
        "commands": [
            {
                "command": "kettu.debugCurrentFileTests",
                "title": "Kettu: Debug Tests in Current File",
                "category": "Kettu",
                "icon": {
                    "light": "./icons/kettu-file.svg",
                    "dark": "./icons/kettu-file.svg"
                }
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "kettu.debugCurrentFileTests",
                    "when": "resourceLangId == kettu",
                    "group": "navigation@9"
                }
            ]
        },
        "breakpoints": [
            {
                "language": "kettu"
            }
        ],
        "debuggers": [
            {
                "type": "kettu",
                "label": "Kettu",
                "languages": [
                    "kettu"
                ],
                "configurationAttributes": {
                    "launch": {
                        "required": [
                            "program"
                        ],
                        "properties": {
                            "program": {
                                "type": "string",
                                "description": "Absolute path to the .kettu file containing tests to debug"
                            },
                            "cwd": {
                                "type": "string",
                                "description": "Working directory for running tests"
                            },
                            "stopOnEntry": {
                                "type": "boolean",
                                "default": false,
                                "description": "Stop before the first test executes"
                            },
                            "kettuPath": {
                                "type": "string",
                                "description": "Path to kettu binary. Defaults to kettu.serverPath resolution"
                            }
                        }
                    }
                },
                "initialConfigurations": [
                    {
                        "name": "Debug Kettu tests (current file)",
                        "type": "kettu",
                        "request": "launch",
                        "program": "${file}",
                        "cwd": "${workspaceFolder}",
                        "stopOnEntry": false
                    }
                ],
                "configurationSnippets": [
                    {
                        "label": "Kettu: Debug tests in current file",
                        "description": "Run Kettu tests in debug mode and stop on Kettu breakpoints",
                        "body": {
                            "name": "Debug Kettu tests (current file)",
                            "type": "kettu",
                            "request": "launch",
                            "program": "${file}",
                            "cwd": "${workspaceFolder}",
                            "stopOnEntry": false
                        }
                    }
                ]
            }
        ],
        "languages": [
            {
                "id": "kettu",
                "aliases": ["Kettu", "kettu"],
                "extensions": [".kettu"],
                "icon": {
                    "light": "./icons/kettu-file.svg",
                    "dark": "./icons/kettu-file.svg"
                },
                "configuration": "./language-configuration.json"
            },
            {
                "id": "wit",
                "aliases": ["WIT", "wit"],
                "extensions": [".wit"],
                "configuration": "./wit-language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "kettu",
                "scopeName": "source.kettu",
                "path": "./syntaxes/kettu.tmLanguage.json"
            },
            {
                "language": "wit",
                "scopeName": "source.wit",
                "path": "./syntaxes/wit.tmLanguage.json"
            },
            {
                "scopeName": "markdown.kettu.codeblock",
                "path": "./syntaxes/kettu-markdown-injection.json",
                "injectTo": ["text.html.markdown"],
                "embeddedLanguages": {
                    "meta.embedded.block.kettu": "kettu"
                }
            },
            {
                "scopeName": "markdown.wit.codeblock",
                "path": "./syntaxes/wit-markdown-injection.json",
                "injectTo": ["text.html.markdown"],
                "embeddedLanguages": {
                    "meta.embedded.block.wit": "wit"
                }
            }
        ],
        "markdown.previewScripts": [
            "./preview/kettu-preview.js",
            "./preview/wit-preview.js"
        ],
        "markdown.previewStyles": [
            "./preview/kettu-preview.css",
            "./preview/wit-preview.css"
        ],
        "iconThemes": [
            {
                "id": "kettu-icons",
                "label": "Kettu Icons",
                "path": "./kettu-icon-theme.json"
            }
        ],
        "mcpServerDefinitionProviders": [
            {
                "id": "kettuMcpProvider",
                "label": "Kettu MCP Server"
            }
        ],
        "languageModelTools": [
            {
                "name": "kettu-check",
                "displayName": "Kettu Check",
                "modelDescription": "Type-check Kettu/WIT source code",
                "inputSchema": {
                    "type": "object",
                    "properties": {
                        "source": {
                            "type": "string",
                            "description": "Kettu source code to check"
                        }
                    },
                    "required": ["source"]
                }
            },
            {
                "name": "kettu-docs-search",
                "displayName": "Kettu Docs Search",
                "modelDescription": "Search the Kettu language guide by keyword",
                "inputSchema": {
                    "type": "object",
                    "properties": {
                        "query": {
                            "type": "string",
                            "description": "Search query (e.g. 'lists', 'async', 'pattern matching')"
                        }
                    },
                    "required": ["query"]
                }
            },
            {
                "name": "kettu-docs-read",
                "displayName": "Kettu Docs Read",
                "modelDescription": "Read a specific topic from the Kettu language guide",
                "inputSchema": {
                    "type": "object",
                    "properties": {
                        "topic": {
                            "type": "string",
                            "description": "Topic number (e.g. '1.2' for Data Types)"
                        }
                    },
                    "required": ["topic"]
                }
            },
            {
                "name": "kettu-emit-wit",
                "displayName": "Kettu Emit WIT",
                "modelDescription": "Strip Kettu extensions and emit pure WIT",
                "inputSchema": {
                    "type": "object",
                    "properties": {
                        "source": {
                            "type": "string",
                            "description": "Kettu source code to convert to WIT"
                        }
                    },
                    "required": ["source"]
                }
            }
        ],
        "configuration": {
            "type": "object",
            "title": "Kettu",
            "properties": {
                "kettu.serverPath": {
                    "type": "string",
                    "default": "",
                    "description": "Path to kettu binary. Leave empty to use PATH."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "node -e \"try{require('fs').chmodSync('./bin/kettu',0o755)}catch(e){}\"",
        "test": "node ./tests/textmate-regex-tests.js && node ./tests/debug-manifest-tests.js && node ./tests/debug-breakpoint-tests.js && node ./tests/debug-values-tests.js"
    },
    "devDependencies": {
        "@types/vscode": "^1.99.0",
        "vscode-languageclient": "^9.0.1"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    }
}
