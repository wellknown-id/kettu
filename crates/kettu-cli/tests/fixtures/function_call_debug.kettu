package local:call-stack-debug;
interface tests {
    type positive = s32 where it > 0;
    make-pos: func(n: positive) -> result<bool, string> {
        result#ok(true)
    }
    @test
    test-result-display: func() -> bool {
        guard let result = make-pos(5) else {
            return false;
        };
        result
    }
}
