// Main module that uses the helper library
package my:app;

/// Application interface
interface app {
    /// Run the app
    run: func() -> s32 {
        let x = math.add(10, 20);
        let y = math.multiply(x, 2);
        return y;
    }
}

world app-world {
    import helper:lib/math;
    export app;
}
