// String Tests
package example:string-tests;

interface string-tests {
    @test
    test-concat: func() -> bool {
        let s = "hello" + " world";
        return true;
    }

    @test
    test-str-len: func() -> bool {
        return str-len("hello") == 5;
    }

    @test
    test-str-len-empty: func() -> bool {
        return str-len("") == 0;
    }

    @test
    test-str-eq-same: func() -> bool {
        let a = "test";
        return str-eq(a, a);
    }
}

world tests {
    export string-tests;
}
