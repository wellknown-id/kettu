// Variant Tests
package example:variant-tests;

interface variant-tests {
    // Define a variant type for qualified variant tests.
    variant my-result {
        ok(s32),
        err(string),
    }

    @test
    test-variant-no-payload: func() -> bool {
        let x = #none;
        return match x {
            #none => true,
            _ => false,
        };
    }

    @test
    test-variant-two-cases: func() -> bool {
        let a = #some;
        let b = #none;
        return a != b;
    }

    @test
    test-variant-with-payload: func() -> bool {
        let y = my-result#ok(42);
        return match y {
            my-result#ok(v) => v == 42,
            my-result#err(_) => false,
        };
    }

    @test
    test-typed-variant-payload: func() -> bool {
        let r = #ok(10);
        return match r {
            #ok(v) => v == 10,
            #err(_) => false,
        };
    }
}

world tests {
    export variant-tests;
}
